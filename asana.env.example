# GitMyNotes -- Asana connector configuration (EXAMPLE / placeholders only).
#
# Copy to a private, UNTRACKED file (e.g. asana.env) and fill in real values,
# or export these in your shell / CI secret store. NEVER commit real tokens.
#
#   cp asana.env.example asana.env      # asana.env is gitignored
#   set -a; source asana.env; set +a    # load into the current shell
#
# The connector is OFF unless GMN_ASANA_ENABLED=1 AND ASANA_ACCESS_TOKEN is set.

# Turn the optional Asana reporting on (1/true/yes/on). Default: off.
GMN_ASANA_ENABLED=0

# Personal Access Token from https://app.asana.com/0/my-apps (Developer console).
# Treat as a secret. Placeholder below -- replace with your own, do not commit.
ASANA_ACCESS_TOKEN=REPLACE_WITH_YOUR_ASANA_PAT

# Workspace GID (optional but recommended). Find via the Asana API or app URL.
ASANA_WORKSPACE_ID=REPLACE_WITH_WORKSPACE_GID

# Project GID where a task will be created per GitMyNotes run. Required to report.
ASANA_PROJECT_GITMYNOTES=REPLACE_WITH_PROJECT_GID

# Advanced: override the API base URL (defaults to https://app.asana.com/api/1.0).
# ASANA_BASE_URL=https://app.asana.com/api/1.0

# Testing only: set to 1 to allow the live-API smoke test in
# test_asana_connector.py to run. Left unset, all tests are fully mocked.
# RUN_LIVE_ASANA_TESTS=0
